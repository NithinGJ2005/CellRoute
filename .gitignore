.env
*.env
*.local

# IDE / OS
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp
*~

# Temporary / Debug
test.js
*.log
*.tmp
*.bak

# Jupyter
.ipynb_checkpoints/
notebooks/.ipynb_checkpoints/

# Node
node_modules/
